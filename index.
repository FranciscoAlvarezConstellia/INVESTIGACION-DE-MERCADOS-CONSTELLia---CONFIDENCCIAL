            --font-body: 'DM Sans', sans-serif;
        }
    </style>
    <style>
        :root {
            --color-bg: #0b0f1e;
            --color-text: #f0f4ff;
            --glow-color-rgb: 124,109,255;
        }
        *, *::before, *::after { box-sizing: border-box; }
        html, body { background: var(--color-bg); margin: 0; }
        body { font-family: 'DM Sans', sans-serif; color: var(--color-text); overflow: hidden; height: 100vh; width: 100vw; }
        .deck { width: 100vw; height: 100vh; position: relative; }
        .slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: var(--color-bg); display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transform: scale(0.96); transition: opacity 0.65s ease, transform 0.65s ease; pointer-events: none; overflow: hidden; }
        .slide.active { opacity: 1; transform: scale(1); pointer-events: all; }
        .slide > .content { position: relative; z-index: 2; width: 100%; max-width: 1140px; padding: clamp(1.5rem, 3.5vw, 3.5rem); }
        .nav-controls { position: fixed; bottom: 26px; left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 14px; z-index: 100; background: rgba(255,255,255,0.05); backdrop-filter: blur(12px); padding: 9px 22px; border-radius: 40px; border: 1px solid rgba(255,255,255,0.09); }
        .nav-btn { width: 38px; height: 38px; border: none; background: rgba(255,255,255,0.06); color: #7c6dff; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.3s; }
        .nav-btn:hover { background: rgba(124,109,255,0.2); }
        .slide-dots { display: flex; gap: 7px; }
        .slide-dots .dot { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.15); cursor: pointer; transition: background 0.3s, transform 0.3s; }
        .slide-dots .dot.active { background: #7c6dff; transform: scale(1.35); }
        .slide-counter { font-size: 0.78rem; color: #7a85a3; min-width: 38px; text-align: center; }
        .reveal { opacity: 0; transform: translateY(18px); }

        /* Glow */
        .text-glow { text-shadow: 0 0 22px rgba(124,109,255,0.55), 0 0 44px rgba(124,109,255,0.22); }
        .stat-glow { text-shadow: 0 0 28px rgba(56,200,240,0.6), 0 0 60px rgba(56,200,240,0.25); }
        @keyframes glow-pulse { 0%,100%{text-shadow:0 0 20px rgba(124,109,255,0.5),0 0 40px rgba(124,109,255,0.2);}50%{text-shadow:0 0 32px rgba(124,109,255,0.8),0 0 64px rgba(124,109,255,0.35);} }
        .glow-pulse { animation: glow-pulse 3s ease-in-out infinite; }

        /* Float blobs */
        @keyframes float-slow { 0%{transform:translate(0,0) scale(1);}25%{transform:translate(55px,-45px) scale(1.1);}50%{transform:translate(-35px,38px) scale(0.92);}75%{transform:translate(48px,18px) scale(1.07);}100%{transform:translate(0,0) scale(1);} }
        @keyframes float-drift { 0%{transform:translate(0,0) scale(1) rotate(0deg);}33%{transform:translate(-48px,-55px) scale(1.13) rotate(3deg);}66%{transform:translate(38px,28px) scale(0.9) rotate(-2deg);}100%{transform:translate(0,0) scale(1) rotate(0deg);} }
        @keyframes float { 0%,100%{transform:translateY(0);}50%{transform:translateY(-14px);} }
        .gradient-mesh { position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
        .blob { position: absolute; border-radius: 50%; filter: blur(82px); animation: float-slow 11s ease-in-out infinite; }
        .blob:nth-child(2) { animation: float-drift 15s ease-in-out infinite; }
        .blob:nth-child(3) { animation: float-slow 19s ease-in-out infinite reverse; }
        .blob:nth-child(4) { animation: float-drift 22s ease-in-out infinite reverse; }

        /* Vignette + noise */
        .slide::before { content:'';position:absolute;inset:0;z-index:1;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px 256px;opacity:0.03;mix-blend-mode:overlay; }
        .slide::after { content:'';position:absolute;inset:0;z-index:1;pointer-events:none;background:radial-gradient(ellipse at center,transparent 50%,var(--color-vignette) 100%); }

        /* Bar chart */
        .bar-chart { display:flex;align-items:flex-end;gap:clamp(0.4rem,1vw,0.7rem);height:clamp(110px,18vh,180px); }
        .bar-col { display:flex;flex-direction:column;align-items:center;gap:0.28rem;flex:1; }
        .bar { border-radius:6px 6px 0 0;width:100%; }
        .bar-fill { height:0%;transition:height 0.55s ease;display:block;border-radius:6px 6px 0 0; }

        /* Donut */
        .donut-ring { stroke-dasharray:251.3;stroke-dashoffset:251.3;stroke-linecap:round; }

        /* Horizontal bars */
        .hbar-track { background:rgba(255,255,255,0.07);border-radius:999px;overflow:hidden;height:10px; }
        .hbar-fill { height:100%;border-radius:999px;width:0;transition:width 0.65s ease; }

        /* Flowchart connectors */
        .flow-arrow { width:2px;height:32px;background:linear-gradient(to bottom,#7c6dff,#38c8f0);margin:0 auto;position:relative; }
        .flow-arrow::after { content:'';position:absolute;bottom:-6px;left:50%;transform:translateX(-50%);width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:8px solid #38c8f0; }

        /* Timeline */
        .tl-line { position:absolute;left:50%;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,#7c6dff,#38c8f0,#f0a842);transform:translateX(-50%); }
        .tl-dot { width:14px;height:14px;border-radius:50%;background:#7c6dff;box-shadow:0 0 12px rgba(124,109,255,0.7);position:absolute;left:50%;transform:translateX(-50%); }

        /* Reduced motion */
        @media (prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms !important;transition-duration:0.2s !important;}}

        /* === SLIDE SPECIFIC === */
        .slide-1 .logo-pill { background:rgba(124,109,255,0.12);border:1px solid rgba(124,109,255,0.25);border-radius:999px;padding:0.5rem 1.5rem;display:inline-block;margin-bottom:1.2rem; }
        .metric-card { background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:1.1rem 1rem;transition:transform 0.25s,box-shadow 0.25s; }
        .metric-card:hover { transform:translateY(-4px);box-shadow:0 12px 30px rgba(124,109,255,0.18); }
        .glass-card { background:rgba(255,255,255,0.05);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,0.09);border-radius:14px;padding:1.3rem; }
        .glass-card:hover { transform:translateY(-3px);box-shadow:0 10px 28px rgba(124,109,255,0.15); }
        .accent-border-l { border-left:3px solid #7c6dff; }
        .accent-border-l-2 { border-left:3px solid #38c8f0; }
        .accent-border-l-3 { border-left:3px solid #f0a842; }
        .tag-pill { display:inline-block;padding:0.2rem 0.75rem;border-radius:999px;font-size:0.72rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase; }

        /* Radar chart */
        .radar-shape { stroke-dasharray:600;stroke-dashoffset:600;transition:stroke-dashoffset 1s ease; }

        /* Deco shapes parallax */
        .deco-shape { position:absolute;pointer-events:none;will-change:transform;transition:transform 0.1s linear; }
    </style>
</head>
